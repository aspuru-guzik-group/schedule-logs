# =============================================================================
[ml]
admin_password = ""
sender_email = ""
smtp_password = ""
smtp_server = ""
smtp_port = 587
organizer_name = ""
folder_id = ""
slides_folder_id = ""
slides_template_id = ""
zoom_link = ""
spreadsheet_id = ""
